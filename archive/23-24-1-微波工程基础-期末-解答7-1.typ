#import "@preview/cetz:0.4.2"
#set page(width:auto,height:auto,margin:0pt)
#cetz.canvas(
	{
		import cetz.draw:*
		set-style(circle:(radius:.1))
		circle((0,0),name:"a1")
		circle((3,0),name:"b2")
		circle((0,-2),name:"b1")
		circle((3,-2),name:"a2")
		circle((0,-4),name:"a3")
		circle((3,-4),name:"b3")
		content("a1",anchor:"east",padding:.1,$a_1$)
		content("b1",anchor:"east",padding:.1,$b_1$)
		content("a3",anchor:"east",padding:.1,$a_3$)
		content("b2",anchor:"north-west",padding:.2,$b_2$)
		content("a2",anchor:"west",padding:.2,$a_2$)
		content("b3",anchor:"west",padding:.2,$b_3$)
		set-style(mark:(end:(symbol:">",pos:50%,shorten-to:none),fill:black))
		line("a1","b2",name:"a1b2")
		line("b2","a2",name:"b2a2")
		line("a2","b1",name:"a2b1")
		line("a1","b1",name:"a1b1")
		line("a2","b3",name:"a2b3")
		line("b3","a3",name:"b3a3")
		line("a3","b1",name:"a3b1")
		line("a3",(rel:(0,-1.5)),(rel:(4.5,0)),(rel:(0,5.5)),"b2",name:"a3b2")
		content("a1b2",anchor:"north",padding:.1,$S_21$)
		content("b2a2",anchor:"east",$Gamma_2$)
		content("a2b1",anchor:"south",padding:.1,$S_12$)
		content("a1b1",anchor:"west",$S_11$)
		content("a2b3",anchor:"east",$S_32$)
		content("b3a3",anchor:"south",padding:.1,$Gamma_3$)
		content("a3b1",anchor:"west",$S_13$)
		content(((rel:(0,-2)),90%,(rel:(4.5,0))),anchor:"north",$S_23$)
	}
)
