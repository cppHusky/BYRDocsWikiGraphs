#set page(width:auto,height:auto,margin:0pt)
#import "@preview/cetz:0.5.2"
#cetz.canvas(x:12mm,y:12mm,{
	import cetz.draw:*
	content((-.5,0),$d_k$,name:"dk")
	rect((.8,-.2),(1.2,.2),name:"d1")
	content("d1",$D$)
	rect((1.8,-.2),(2.2,.2),name:"d2")
	content("d2",$D$)
	let oplus(p,name)={
		circle(p,radius:.15,name:name)
		content(name,move(dy:-.5pt,text(size:14pt,$+$)))
	}
	oplus((1.5,1),"op1")
	oplus((2.5,1),"op2")
	oplus((2.5,-1),"op3")
	oplus((3,-2),"op4")
	content((4,1),$c_(1,k)$,name:"c1")
	content((4,-1),$c_(2,k)$,name:"c2")
	content((4,-2),$c_(3,k)$,name:"c3")
	line("dk","d1")
	set-style(line:(
		mark:(end:(symbol:">",fill:black))
	))
	line((0,0),(horizontal:(),vertical:"op4"),"op4")
	line((0,0),(horizontal:(),vertical:"op1"),"op1")
	line("d1","d2")
	line("d2",(vertical:(),horizontal:"op2"),(horizontal:"op4",vertical:(0,-.3)),"op4")
	line("op1","op2")
	line("op2","c1")
	line("op3","c2")
	line("op4","c3")
	line((2.5,0),"op2")
	line((2.5,0),"op3")
	line("op3",(horizontal:"op1",vertical:()),(1.5,0),"op1")
	let dot(p)=circle(p,radius:.04,fill:black)
	dot((0,0))
	dot((1.5,0))
	dot((2.5,0))
})
