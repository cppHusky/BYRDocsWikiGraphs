#set page(width:auto,height:auto,margin:0pt)
#import "@preview/cetz:0.5.2"
#cetz.canvas(x:12mm,y:12mm,{
	import cetz.draw:*
	set-style(content:(
		padding:1pt,
	))
	line((-.2,0),(10,0),name:"abus")
	content(("abus.start",95%,"abus.end"),[ABUS],anchor:"south")
	line((-.2,-1),(10,-1),name:"dbus")
	content(("dbus.start",95%,"dbus.end"),[DBUS],anchor:"south")
	rect((.5,-3),(2,-2),name:"mar")
	content("mar",[MAR])
	rect((3,-3),(4.5,-2),name:"mdr")
	content("mdr",[MDR])
	rect((6,-3),(8,-2),name:"meu")
	content("meu",[MEU])
	line((-.2,-4),(10,-4),name:"ibus")
	content(("ibus.start",95%,"ibus.end"),[IBUS],anchor:"south")
	rect((1.5,-6),(2.5,-5),name:"t1")
	content("t1",[T1])
	rect((3.5,-6),(4.5,-5),name:"t2")
	content("t2",[T2])
	rect((6.5,-7.5),(8,-6.5),name:"ir")
	content("ir",[IR])
	rect((7.5,-6),(9,-5),name:"pc")
	content("pc",[PC])
	line((1.5,-7),(2,-8.5),(4,-8.5),(4.5,-7),(3.5,-7),(3.3,-7.5),(2.7,-7.5),(2.5,-7),close:true,name:"alu")
	content("alu",[ALU])
	let arrow=(symbol:">",fill:black)
	let dot=(symbol:"o",fill:black)
	set-style(circle:(
		radius:.1,
		fill:white,
	))
	line("mar.north",(horizontal:(),vertical:"abus"),mark:(end:arrow),name:"mar2ab")
	circle(("mar2ab.start",.5,"mar2ab.end"),name:"mar2ab-c")
	content("mar2ab-c.west",[MAR2AB],anchor:"east")
	line((rel:(-.2,0),to:"mdr.north"),(horizontal:(),vertical:"dbus"),mark:(end:arrow),name:"mdr2db")
	circle(("mdr2db.start",.5,"mdr2db.end"),name:"mdr2db-c")
	content("mdr2db-c.west",[MDR2DB],anchor:"east")
	line((rel:(.2,0),to:"mdr.north"),(horizontal:(),vertical:"dbus"),mark:(start:arrow),name:"db2mdr")
	circle(("db2mdr.start",.5,"db2mdr.end"),name:"db2mdr-c")
	content("db2mdr-c.east",[DB2MDR],anchor:"west")
	line((rel:(-.6,0),to:"meu.north"),(horizontal:(),vertical:"abus"),mark:(end:dot))
	line((rel:(-.2,0),to:"meu.north"),(horizontal:(),vertical:"dbus"),mark:(end:dot))
	content((rel:(.3,.7),to:"meu.north"),[RD],name:"rd")
	line("rd",(horizontal:(),vertical:"meu.north"),mark:(end:arrow))
	content((rel:(.9,.7),to:"meu.north"),[WT],name:"wt")
	line("wt",(horizontal:(),vertical:"meu.north"),mark:(end:arrow))
	line("mar",(horizontal:(),vertical:"ibus"),mark:(start:arrow),name:"ib2mar")
	content("ib2mar",[IB2MAR],anchor:"east")
	line((to:"mdr.south",rel:(-.3,0)),(horizontal:(),vertical:"ibus"),mark:(start:arrow),name:"ib2mdr")
	content("ib2mdr",[IB2MDR],anchor:"east")
	line((to:"mdr.south",rel:(.3,0)),(horizontal:(),vertical:"ibus"),mark:(end:arrow),name:"mdr2ib")
	circle(("mdr2ib.start",.5,"mdr2ib.end"),name:"mdr2ib-c")
	content("mdr2ib-c.east",[MDR2IB],anchor:"west")
	line("t1",(horizontal:(),vertical:"ibus"),mark:(start:arrow),name:"ib2t1")
	content("ib2t1",[IB2T1],anchor:"west")
	line("t2",(horizontal:(),vertical:"ibus"),mark:(start:arrow),name:"ib2t2")
	content("ib2t2",[IB2T2],anchor:"east")
	line("t1",(horizontal:(),vertical:(to:"alu",rel:(0,.75))))
	line("t2",(horizontal:(),vertical:(to:"alu",rel:(0,.75))))
	line((to:"alu",rel:(0,-.75)),(rel:(0,-1)),(rel:(-3,0)),(horizontal:(),vertical:"ibus"),mark:(end:arrow),name:"alu2ib")
	circle(("alu2ib.1.5",50%,"alu2ib.3.5"),name:"alu2ib-c")
	content("alu2ib-c.south",[ALU2IB],anchor:"north")
	line((to:"ir.west",rel:(0,.1)),(rel:(-.5,0)),(horizontal:(),vertical:"ibus"),mark:(end:arrow),name:"ira2ib")
	circle(("ira2ib.end",1.5,"ira2ib.0.5"),name:"ira2ib-c")
	content("ira2ib-c.north",[IRA2IB],anchor:"south")
	line((to:"ir.west",rel:(0,-.2)),(rel:(-1.25,0)),(horizontal:(),vertical:"ibus"),mark:(end:arrow),name:"irb2ib")
	circle(("irb2ib.end",1.5,"irb2ib.1.25"),name:"irb2ib-c")
	content("irb2ib-c.south",[IRB2IB],anchor:"north")
	line("ir",(horizontal:(),vertical:"ibus"),mark:(start:arrow),name:"ib2ir")
	content(("ib2ir.start",15%,"ib2ir.end"),[IB2IR],anchor:"west")
	line((to:"pc.north",rel:(-.2,0)),(horizontal:(),vertical:"ibus"),name:"pc2ib")
	circle(("pc2ib.start",50%,"pc2ib.end"),name:"pc2ib")
	content("pc2ib.north",[PC2IB],anchor:"south")
	line((to:"pc.north",rel:(.2,0)),(horizontal:(),vertical:"ibus"),mark:(start:arrow),name:"ib2pc")
	content("ib2pc",[IB2PC],anchor:"west")
	content((to:"pc.east",rel:(1,-.2)),[PC+1],name:"pc+1")
	line("pc+1",(horizontal:"pc.east",vertical:()),mark:(end:arrow))
	content((to:"alu",rel:(-2.25,0)),[ADD],name:"add")
	line("add","alu",mark:(end:arrow))
})
