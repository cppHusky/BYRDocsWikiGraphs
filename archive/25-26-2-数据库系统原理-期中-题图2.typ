#import "@preview/cetz:0.5.0"
#set page(width:auto,height:auto,margin:0pt)
#cetz.canvas({
	import cetz.draw:*
	let e(pos,width,height,name,head,contents)={
		rect(pos,(rel:(width,-.5)),fill:silver,name:name+"-h")
		rect(pos,(rel:(width,-height)),name:name+"-c")
		content(
			pos,
			(rel:(width/2,+.5)),
			emph(strong(name)),
		)
		content(
			(to:pos,rel:(.1,-.1)),
			(rel:(width,-.5)),
			emph(head),
		)
		content(
			(to:pos,rel:(.1,-.6)),
			(rel:(width,-height)),
			emph(contents),
		)
	}
	let r(pos,width,height,name,contents)={
		rect(pos,(rel:(width,-height)),name:name+"-c")
		content(
			pos,
			(rel:(width/2,+.5)),
			emph(strong(name)),
		)
		content(
			(to:pos,rel:(.1,-.1)),
			(rel:(width,-.5)),
			emph(contents),
		)
	}
	e((0,0),2.4,1.5,"branch",[branch_name],[branch_city#linebreak()assets])
	e((4,0),3,1.5,"account",[account_number],[branch_name#linebreak()balance])
	e((6,-4),2.4,1.5,"loan",[loan_number],[branch_name#linebreak()amount])
	e((14,0),3,1.5,"customer",[customer_name],[customer_street#linebreak()customer_city])
	r((9,0),3,1.5,"depositor",[customer_name#linebreak()account_number])
	r((12,-4),3,1.5,"borrower",[customer_name#linebreak()loan_number])
	set-style(
		line:(mark:(end:(symbol:">",fill:black)))
	)
	line(
		"account-c.west",
		(rel:(-.8,0)),
		(rel:(.8,0),to:"branch-h.east"),
		"branch-h.east",
	)
	line(
		"depositor-c.west",
		(rel:(-1,0)),
		(rel:(1,0),to:"account-h.east"),
		"account-h.east",
	)
	line(
		(rel:(0,.5),to:"depositor-c.east"),
		"customer-h.west",
	)
	line(
		"loan-c.west",
		(rel:(-3,0)),
		(rel:(.6,-.6),to:"branch-h.east"),
		(rel:(0,-.1),to:"branch-h.east"),
	)
	line(
		"borrower-c.east",
		(rel:(.5,0)),
		(rel:(0,2)),
		(rel:(-2.1,0)),
		(rel:(0,1.8)),
		(rel:(-.6,-.6),to:"customer-h.west"),
		(rel:(0,-.1),to:"customer-h.west"),
	)
	line(
		"borrower-c.west",
		(rel:(-1.8,0)),
		(rel:(1.8,0),to:"loan-h.east"),
		"loan-h.east",
	)
})
